# Food Search API keys
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Vite exposes vars prefixed with VITE_ to the browser at build time.
#
# Without keys, the app silently falls back to a local mock food database
# (~30 common Indian & Western items). Search still works — just with a
# smaller catalog and no branded products.

# Nutritionix — primary provider
# Sign up (free, 200 requests/day): https://developer.nutritionix.com/
VITE_NUTRITIONIX_APP_ID=
VITE_NUTRITIONIX_APP_KEY=

# USDA FoodData Central — automatic fallback when Nutritionix quota is hit
# Sign up (free, 1000 requests/hour): https://fdc.nal.usda.gov/api-key-signup.html
VITE_USDA_API_KEY=
